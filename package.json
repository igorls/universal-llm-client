{
  "name": "@akaito/universal-llm-client",
  "version": "1.0.0",
  "type": "module",
  "description": "A high-performance, state-of-the-art universal client for Large Language Models that supports multiple API providers, including Ollama and OpenAI-compatible endpoints.",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./factory": {
      "import": "./dist/factory.js",
      "types": "./dist/factory.d.ts"
    },
    "./interfaces": {
      "import": "./dist/interfaces.js",
      "types": "./dist/interfaces.d.ts"
    },
    "./tools": {
      "import": "./dist/tools.js",
      "types": "./dist/tools.d.ts"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "npm run clean && npm run compile",
    "clean": "rimraf dist",
    "compile": "tsc --project tsconfig.json",
    "dev": "tsc --watch --project tsconfig.json",
    "prepublishOnly": "npm run build",
    "test": "npm run build && npm run test:node",
    "test:node": "node --test __tests__/1-initialization-node.test.js __tests__/dependency-injection-node.test.js",
    "test:fast": "npm run build && node --test __tests__/fast-tests-node.test.js",
    "test:full": "node --test __tests__/1-initialization-node.test.js __tests__/dependency-injection-node.test.js __tests__/mockagent-integration-node.test.js",
    "test:node:watch": "node --test --watch __tests__/**/*-node.test.js",
    "test:node:coverage": "npm run build && node --test --experimental-test-coverage __tests__/**/*-node.test.js",
    "typecheck": "tsc --noEmit",
    "lint": "tsc --noEmit --strict",
    "prepack": "npm run build"
  },
  "keywords": [
    "llm",
    "ai",
    "artificial-intelligence",
    "openai",
    "ollama",
    "google-gemini",
    "chat-completion",
    "embeddings",
    "undici",
    "http-client",
    "streaming",
    "tool-calling",
    "function-calling",
    "typescript",
    "esm",
    "nodejs"
  ],
  "dependencies": {
    "undici": "^7.12.0"
  },
  "devDependencies": {
    "@types/node": "^24.0.14",
    "rimraf": "^6.0.1",
    "typescript": "^5.8.3"
  },
  "peerDependencies": {
    "@types/node": ">=20.0.0"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/igorls/aura-companion.git",
    "directory": "backend/src/universal-llm-client"
  }
}
